{
  "name": "kiro-provider",
  "version": "0.1.0",
  "description": "Standalone AWS Kiro (CodeWhisperer) provider service",
  "type": "module",
  "private": true,
  "scripts": {
    "fmt": "bunx --bun @biomejs/biome format --write ./src ./scripts ./__tests__",
    "lint": "bunx --bun @biomejs/biome check ./src ./scripts ./__tests__",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build src/cli/main.ts --outdir dist --target bun",
    "build:binary": "bun build --compile --minify src/cli/main.ts --outfile dist/kiro-provider"
  },
  "dependencies": {
    "@aws/codewhisperer-streaming-client": "^1.0.34",
    "@smithy/node-http-handler": "4.9.7",
    "https-proxy-agent": "^9.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@types/bun": "^1.3.6",
    "@types/node": "^20.0.0",
    "typescript": "^5.7.3"
  }
}
